         0 / number of parameters                           ZGCOUNT =                    1 / number of groups                               ZTILE1  =                   32 / size of tiles to be compressed                 ZTILE2  =                   32 / size of tiles to be compressed                 ZCMPTYPE= 'GZIP_2  '           / compression algorithm                          EXTNAME = 'MASK    '           / name of this binary table extension            MSKN0000= 'NO_DATA '           / Name for mask plane 0.                         MSKM0000=                    1 / Bitmask for plane n=0; always 1<<n.            MSKD0000= 'No data was available for this pixel.'                               MSKN0001= 'INTERPOLATED'       / Name for mask plane 1.                         MSKM0001=                    2 / Bitmask for plane n=1; always 1<<n.            MSKD0001= 'Pixel value is the result of interpolating nearby good pixels.'      MSKN0002= 'COSMIC_RAY'         / Name for mask plane 2.                         MSKM0002=                    4 / Bitmask for plane n=2; always 1<<n.            MSKD0002= 'A cosmic ray affected this pixel on at least one input image (and &' CONTINUE  'was interpolated).'                                                  MSKN0003= 'SATURATED'          / Name for mask plane 3.                         MSKM0003=                    8 / Bitmask for plane n=3; always 1<<n.            MSKD0003= 'More than 10% of the potential input visits had a saturated pixel &' CONTINUE  'at this location (''potential'' because saturated pixel values are &'CONTINUE  'not actually propagated to the coadd). SATURATED always implies &'   CONTINUE  'REJECTED, and is often a reason for NO_DATA.'                        MSKN0004= 'DETECTION_EDGE'     / Name for mask plane 4.                         MSKM0004=                   16 / Bitmask for plane n=4; always 1<<n.            MSKD0004= 'Pixel was too close to the edge of the patch to be considered for &' CONTINUE  'detection, due to the finite size of the detection kernel.'          MSKN0005= 'CLIPPED '           / Name for mask plane 5.                         MSKM0005=                   32 / Bitmask for plane n=5; always 1<<n.            MSKD0005= 'Region was identified as a probable artifact when comparing &'       CONTINUE  'multiple single-visit warps. CLIPPED always implies REJECTED.'       MSKN0006= 'REJECTED'           / Name for mask plane 6.                         MSKM0006=                   64 / Bitmask for plane n=6; always 1<<n.            MSKD0006= 'At least one input visit was left out of the coadd for this pixel &' CONTINUE  'due to masking. REJECTED always implies INEXACT_PSF.'                MSKN0007= 'DETECTED'           / Name for mask plane 7.                         MSKM0007=                  128 / Bitmask for plane n=7; always 1<<n.            MSKD0007= 'Pixel was part of a detected source.'                                MSKN0008= 'INEXACT_PSF'        / Name for mask plane 8.                         MSKM0008=                  256 / Bitmask for plane n=8; always 1<<n.            MSKD0008= 'The set of visits contributing to this pixel differs from the set &' CONTINUE  'of visits contributing to the PSF model for its cell.'               WCSAXES =                    2 / Number of coordinate axes                      CRPIX1  =            41.128586 / Pixel coordinate of reference point            CRPIX2  =            17.996563 / Pixel coordinate of reference point            PC1_1   =  5.9036335991114E-05 / Coordinate transformation matrix element       PC2_2   =  6.0141728636419E-05 / Coordinate transformation matrix element       CDELT1  =                  1.0 / [deg] Coordinate increment at reference point  CDELT2  =                  1.0 / [deg] Coordinate increment at reference point  CUNIT1  = 'deg'                / Units of coordinate increment and value        CUNIT2  = 'deg'                / Units of coordinate increment and value        CTYPE1  = 'RA---TAN'